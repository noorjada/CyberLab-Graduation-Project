# Server
PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/cyberlab
JWT_SECRET=change-this-to-a-long-random-secret

# Client URL (comma-separated for multiple origins)
CLIENT_URL=http://localhost:3000

# Email (optional — password reset & verification)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=CyberLab <noreply@cyberlab.local>

# AI mentor (Groq)
GROQ_API_KEY=your-groq-api-key

# Recon lab (ipinfo.io)
IPINFO_TOKEN=your-ipinfo-token

# Malware lab (VirusTotal)
VIRUSTOTAL_API_KEY=your-virustotal-api-key

# CVE feed (optional — higher rate limits)
NVD_API_KEY=

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Certificate PDF — admin signature (see assets/signatures/README.md)
CERT_ADMIN_NAME=Haitham
CERT_ADMIN_TITLE=Founder & Administrator, CyberLab
# CERT_SIGNATURE_PATH=./assets/signatures/admin-signature.png
